{
  "name": "lighthouse-clients",
  "private": true,
  "version": "0.1.0",
  "description": "Workspace for Lighthouse client, CLI, and MCP packages",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "clean": "rimraf packages/*/dist packages/*/dist-types *.tsbuildinfo packages/*/*.tsbuildinfo",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b tsconfig.json --pretty false",
    "ci": "pnpm lint && pnpm test && pnpm typecheck && pnpm build",
    "changeset": "changeset",
    "release:version": "changeset version",
    "release:publish": "changeset publish",
    "release:status": "changeset status"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
