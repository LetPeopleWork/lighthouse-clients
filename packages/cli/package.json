{
  "name": "@letpeoplework/lighthouse-cli",
  "version": "0.11.0",
  "description": "User-facing Lighthouse CLI",
  "repository": "https://github.com/LetPeopleWork/lighthouse-clients",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "lh": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./bin": {
      "types": "./dist/bin.d.ts",
      "import": "./dist/bin.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm --filter @letpeoplework/lighthouse-client build && tsup && pnpm postbuild",
    "postbuild": "node scripts/fix-shebang.mjs",
    "clean": "rimraf dist"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@toon-format/toon": "^2.1.0",
    "@letpeoplework/lighthouse-client": "workspace:*",
    "undici": "^8.1.0"
  }
}
