{
  "name": "@letpeoplework/lighthouse-mcp-stdio",
  "version": "0.2.4",
  "description": "stdio transport adapter for Lighthouse MCP",
  "repository": "https://github.com/LetPeopleWork/lighthouse-clients",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "clean": "rimraf dist"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@letpeoplework/lighthouse-mcp-core": "workspace:*"
  }
}
