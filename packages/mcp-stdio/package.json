{
  "name": "@letpeoplework/lighthouse-mcp-stdio",
  "version": "0.8.0",
  "description": "stdio transport adapter for Lighthouse MCP",
  "repository": "https://github.com/LetPeopleWork/lighthouse-clients",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "lighthouse-mcp-stdio": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./bin": {
      "types": "./dist/bin.d.ts",
      "import": "./dist/bin.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && pnpm postbuild",
    "postbuild": "node scripts/fix-shebang.mjs",
    "clean": "rimraf dist"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@letpeoplework/lighthouse-client": "workspace:*",
    "@letpeoplework/lighthouse-mcp-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "undici": "^8.1.0"
  }
}
