{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "verbatimModuleSyntax": true,
    "types": ["vitest/globals", "node"],
    "paths": {
      "@letpeoplework/lighthouse-client": ["./packages/client/src/index.ts"],
      "@letpeoplework/lighthouse-cli": ["./packages/cli/src/index.ts"],
      "@letpeoplework/lighthouse-mcp-core": [
        "./packages/mcp-core/src/index.ts"
      ],
      "@letpeoplework/lighthouse-mcp-http": [
        "./packages/mcp-http/src/index.ts"
      ],
      "@letpeoplework/lighthouse-mcp-stdio": [
        "./packages/mcp-stdio/src/index.ts"
      ]
    }
  }
}
